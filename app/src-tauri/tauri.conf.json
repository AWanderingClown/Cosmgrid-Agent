{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cosmgrid Agent",
  "version": "0.1.0",
  "identifier": "com.cosmgrid.agent",
  "build": {
    "beforeDevCommand": "node_modules/.bin/vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node_modules/.bin/vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cosmgrid Agent",
        "width": 800,
        "height": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
