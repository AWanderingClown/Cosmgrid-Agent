{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-save-api-key",
    "allow-get-api-key",
    "allow-delete-api-key",
    "allow-spawn-cli-stream",
    "allow-kill-cli",
    "allow-spawn-rpc-process",
    "allow-write-rpc-stdin",
    "allow-kill-rpc-process",
    "allow-resolve-cli-program",
    "allow-run-shell-command",
    "allow-run-shell-args",
    "allow-fetch-url-backend",
    "allow-fetch-url-rendered",
    "allow-git-commit-file",
    "allow-git-read",
    "allow-init-shadow-git-repo",
    "allow-resolve-realpath",
    "allow-grant-workspace-fs-access",
    "allow-set-menu-language",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-save",
    "store:allow-load",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$HOME/**" }],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.env*" },
        { "path": "**/.env*" },
        { "path": "**/secrets.*" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/**" }],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.env*" },
        { "path": "**/.env*" },
        { "path": "**/secrets.*" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "$HOME/**" }],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.env*" },
        { "path": "**/.env*" },
        { "path": "**/secrets.*" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$HOME/**" }],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.env*" },
        { "path": "**/.env*" },
        { "path": "**/secrets.*" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "$HOME/**" }],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.env*" },
        { "path": "**/.env*" },
        { "path": "**/secrets.*" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**" }],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.env*" },
        { "path": "**/.env*" },
        { "path": "**/secrets.*" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$HOME/**" }],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.env*" },
        { "path": "**/.env*" },
        { "path": "**/secrets.*" }
      ]
    },
    "dialog:allow-open"
  ]
}
