#!/usr/bin/env sh

# 预提交检查 — tsc（类型检查）+ depcruise（依赖规则）
# 不对全仓做格式化，只做代码质量关键验证
#
# 注意：Node 项目在仓库的 app/ 子目录，git 却总是从仓库根目录跑 hook。
# 之前用 `npx tsc`：根目录找不到本地 TypeScript，npx 会误拉 dependency-confusion
# 占位包 `tsc`（打印警告后退出码 0），导致类型检查形同虚设、静默"通过"。
# 修法：先 cd 进 app/，再直接调本地二进制（./node_modules/.bin/*），不经 npx，杜绝误解析。

cd "$(git rev-parse --show-toplevel)/app" || {
  echo "⚠️  找不到 app/ 目录，pre-commit 无法运行。"
  exit 1
}

if [ ! -x ./node_modules/.bin/tsc ]; then
  echo "⚠️  app/node_modules/.bin/tsc 不存在，请先在 app/ 下装依赖（pnpm install）。"
  exit 1
fi

# 1. 类型检查
./node_modules/.bin/tsc --noEmit
if [ $? -ne 0 ]; then
  echo "⚠️  tsc 类型检查未通过，请修复后重新提交。"
  exit 1
fi

# 2. 依赖检查
./node_modules/.bin/depcruise src --config .dependency-cruiser.cjs
if [ $? -ne 0 ]; then
  echo "⚠️  dependency-cruiser 检查未通过，请修复后重新提交。"
  exit 1
fi

echo "✅ pre-commit 检查通过（tsc + depcruise）"
