#!/usr/bin/env sh

# 预提交检查 — tsc（类型检查）+ depcruise（依赖规则）
# 不对全仓做格式化，只做代码质量关键验证

# 1. 类型检查
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "⚠️  tsc 类型检查未通过，请修复后重新提交。"
  exit 1
fi

# 2. 依赖检查
npx depcruise src --config .dependency-cruiser.cjs
if [ $? -ne 0 ]; then
  echo "⚠️  dependency-cruiser 检查未通过，请修复后重新提交。"
  exit 1
fi

echo "✅ pre-commit 检查通过（tsc + depcruise）"
